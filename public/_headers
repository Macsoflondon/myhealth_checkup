/*
  # UK Cyber Essentials Plus v3.3 — security headers

  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=(), interest-cohort=(), browsing-topics=()
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: same-site
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

  # Content Security Policy — ENFORCING.
  # `'unsafe-eval'` removed (production code does not require it).
  # `http:` removed from img-src so HTTPS is enforced for images too.
  # `upgrade-insecure-requests` mitigates any third-party HTTP URL slipping in.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.gpteng.co; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.openai.com https://api.firecrawl.dev https://storage.googleapis.com https://nominatim.openstreetmap.org; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests; report-uri /csp-report; report-to csp-endpoint

  Reporting-Endpoints: csp-endpoint="/csp-report"

# Long-cache hashed build assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/lovable-uploads/*
  Cache-Control: public, max-age=31536000, immutable

*.webp
  Cache-Control: public, max-age=31536000, immutable

*.woff2
  Cache-Control: public, max-age=31536000, immutable

# HTML: short cache with background revalidation
/index.html
  Cache-Control: public, max-age=300, stale-while-revalidate=60

/sw.js
  Cache-Control: public, max-age=0, must-revalidate

# Long-cache other static asset types
*.png
  Cache-Control: public, max-age=31536000, immutable

*.jpg
  Cache-Control: public, max-age=31536000, immutable

*.svg
  Cache-Control: public, max-age=31536000, immutable

*.mp4
  Cache-Control: public, max-age=31536000, immutable

*.woff
  Cache-Control: public, max-age=31536000, immutable
